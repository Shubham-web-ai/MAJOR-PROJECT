<% layout("layouts/boilerplate.ejs") -%>
<div class="row mt-3">
    <div class=" col-8 offset-2">
<body>
    <h2>Edit Your listings</h2>
    <form method="post" action="/listings/<%=editData.id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" value="<%=editData.title%>" placeholder="Enter title" type="text" class="form-control" required>
            <div class="valid-feedback">Title Looks good!</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required><%=editData.description%></textarea>
            <div class="invalid-feedback">please enter a short description</div>
        </div>
        <div class="mb-3">
            Original Listing Image <br/>
            <img src="<%=originalImageUrl%>"  style="width:300px; height:200px; object-fit:cover;"/>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image </label>
            <input type="file" name="listing[image]" placeholder="enter image url" class="form-control" required>
        </div>
        <div class="row">
            <div class="mb-3 col-4">
                <label for="Price" class="form-label">Price</label>
                <input name="listing[price]" value="<%=editData.price%>" placeholder="Enter price" type="number" class="form-control" required>
                <div class="invalid-feedback">please should be valid</div>
            </div>
            <div class="mb-3 col-8">
                <label for="country" class="form-label">Country</label>
                <input name="listing[country]" value="<%=editData.country%>" placeholder="Enter country" type="text" class="form-control" required>
                <div class="invalid-feedback">Country name should be valid</div>
            </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">location</label>
            <input  name="listing[location]" value="<%=editData.location%>" placeholder="Enter location" type="text" class="form-control" required>
            <div class="invalid-feedback">location should be valid</div>
        </div>
        <button class="btn btn-dark editbtn mt-3">Add</button>
    </form>
</body>
</div>
</div>
<script src="/js/script.js"></script>
